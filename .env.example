# MongoDB connection string (required for the contact form and KOT stream).
# Change Streams (/api/kot/stream) require a replica set — MongoDB Atlas provides this by default.
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/techrestopos

# Public base URL of the deployed site. Used for SEO metadata, sitemap.xml and robots.txt.
# IMPORTANT: set this in production (e.g. on Vercel) or the sitemap falls back to the default below.
NEXT_PUBLIC_APP_URL=https://www.techrestopos.com

# Google Search Console verification token (optional)
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Google Analytics 4 measurement ID (G-XXXX). Falls back to the ID
# hardcoded in layout.tsx if unset. NEXT_PUBLIC_GTM_ID (GTM-XXXX) is
# also supported for Tag Manager setups.
NEXT_PUBLIC_GA_ID=G-PYSCFX1E64

# Resend email notifications for contact-form leads (all three required to send).
# CONTACT_FROM_EMAIL must be a sender on a domain verified in your Resend account.
# CONTACT_TO_EMAIL accepts a comma-separated list.
RESEND_API_KEY=
CONTACT_FROM_EMAIL=techrestoPOS Leads <leads@techrestopos.com>
CONTACT_TO_EMAIL=smitha@etag.in
